# ===========================
# DATABASE CONFIGURATION
# ===========================
POSTGRES_DB=processed_db
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=pipeline_secret_2024

MYSQL_ROOT_PASSWORD=root_secret_2024
MYSQL_DATABASE=source_db
MYSQL_USER=pipeline_user
MYSQL_PASSWORD=pipeline_secret_2024

# ===========================
# KAFKA CONFIGURATION
# ===========================
KAFKA_BROKER=kafka:29092
KAFKA_TOPIC=sensor_readings
KAFKA_ACKS_MODE=all

# ===========================
# SPARK CONFIGURATION
# ===========================
SPARK_MASTER_URL=spark://spark-master:7077
SPARK_APP_NAME=StreamingETL
SPARK_DRIVER_MEMORY=2g
SPARK_EXECUTOR_MEMORY=1g

# ===========================
# AIRFLOW CONFIGURATION
# ===========================
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=airflow_admin_2024

# ===========================
# MINIO / S3 CONFIGURATION
# ===========================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio_secret_2024
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_RAW=raw-data
MINIO_BUCKET_PROCESSED=processed-data

# ===========================
# MONITORING
# ===========================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASS=admin_secret_2024

# ===========================
# MLFLOW CONFIGURATION
# ===========================
MLFLOW_TRACKING_URI=http://mlflow:5000

# ===========================
# REDIS CONFIGURATION
# ===========================
REDIS_HOST=redis
REDIS_PORT=6379

# ===========================
# MONGODB CONFIGURATION
# ===========================
MONGODB_URI=mongodb://mongodb:27017/
MONGODB_DB=iot_data

# ===========================
# INFLUXDB CONFIGURATION
# ===========================
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=pipeline-influx-token
INFLUXDB_ORG=pipeline-org
INFLUXDB_BUCKET=iot_data

# ===========================
# SNOWFLAKE DATA WAREHOUSE
# ===========================
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=PIPELINE_WH
SNOWFLAKE_DATABASE=PIPELINE_DB
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_ROLE=PIPELINE_ROLE

# ===========================
# GOVERNANCE
# ===========================
ATLAS_API_URL=http://atlas:21000/api/atlas/v2
ATLAS_USERNAME=admin
ATLAS_PASSWORD=admin
