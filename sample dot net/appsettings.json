{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      { "Name": "File", "Args": { "path": "logs/api-.log", "rollingInterval": "Day", "retainedFileCountLimit": 14 } }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithEnvironmentName"]
  },
  "ConnectionStrings": {
    "MySql": "Server=mysql;Port=3306;Database=source_db;User=pipeline_user;Password=pipeline_secret_2024;Connection Timeout=30;",
    "Postgres": "Host=postgres;Port=5432;Database=processed_db;Username=pipeline_user;Password=pipeline_secret_2024;Timeout=30;",
    "CommandTimeoutSeconds": 30
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "AccessKey": "minio",
    "SecretKey": "minio_secret_2024",
    "BucketRaw": "raw-data",
    "BucketProcessed": "processed-data",
    "MaxUploadRetries": 3
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "Topic": "sensor_readings",
    "ClientId": "data-pipeline-api",
    "MessageTimeoutMs": 5000,
    "ProducerFlushSeconds": 2
  },
  "Airflow": {
    "BaseUrl": "http://airflow-webserver:8080/api/v1",
    "Username": "admin",
    "Password": "airflow_admin_2024",
    "BatchDagId": "batch_ingestion_dag",
    "StreamingDagId": "streaming_monitoring_dag",
    "WarehouseDagId": "warehouse_transform_dag",
    "RequestTimeoutSeconds": 30
  },
  "GreatExpectations": {
    "CliPath": "/usr/local/bin/great_expectations",
    "TimeoutSeconds": 300
  },
  "Atlas": {
    "Endpoint": "http://atlas:21000/api/atlas/v2",
    "Username": "admin",
    "Password": "admin"
  },
  "MLflow": {
    "TrackingUri": "http://mlflow:5000",
    "RequestTimeoutSeconds": 30
  },
  "GitHub": {
    "ActionsApi": "https://api.github.com/repos/hoangsonww/End-to-End-Data-Pipeline/actions/workflows",
    "Token": "",
    "UserAgent": "data-pipeline-api/2.0"
  },
  "Snowflake": {
    "Account": "",
    "User": "",
    "Password": "",
    "Warehouse": "PIPELINE_WH",
    "Database": "PIPELINE_DB",
    "Schema": "ANALYTICS",
    "Role": "PIPELINE_ROLE"
  },
  "AllowedHosts": "*"
}
